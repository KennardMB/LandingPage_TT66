---
interface Props {
	title?: string;
}
const { title = 'Tirta Taruna 66 · Aquatic Swimming Club' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<link rel="icon" type="image/png" href="/favicon.png" />
	<title>{title}</title>
</head>
<body>
	<div class="wrap">
		<nav>
			<a href="/" class="brand">
				<img src="/logo/tt66-logo.png" alt="Tirta Taruna 66 logo" class="logo-mark" />
				Tirta Taruna 66
			</a>
			<div class="navlinks" data-navlinks>
				<a href="/#about">About</a>
				<a href="/#programs">Programs</a>
				<a href="/#achievements">Achievements</a>
				<a href="/#coaches">Coaches &amp; Staff</a>
				<a href="/#contact">Contact</a>
			</div>
			<button class="nav-toggle" data-nav-toggle aria-label="Toggle menu" aria-expanded="false">
				<span></span><span></span><span></span>
			</button>
		</nav>

		<slot />

		<footer>
			<div class="fbrand">tirta taruna 66</div>
			<div class="fnote">Senayan · Jakarta · Est. 1966</div>
		</footer>
	</div>
</body>
</html>

<script>
	const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
	const navlinks = document.querySelector<HTMLElement>('[data-navlinks]');

	toggle?.addEventListener('click', () => {
		const open = navlinks?.classList.toggle('open');
		toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
	});

	navlinks?.addEventListener('click', (e) => {
		if ((e.target as HTMLElement).tagName === 'A') {
			navlinks.classList.remove('open');
			toggle?.setAttribute('aria-expanded', 'false');
		}
	});
</script>

<style is:global>
	:root {
		--blue: #5166dc;
		--blue-deep: #4253b4;
		--blue-deeper: #3a49a0;
		--paper: #ebeae8;
		--muted: #9fa9e1;
		--ink: #20264a;
		--red: #e50112;
	}
	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}
	html {
		-webkit-font-smoothing: antialiased;
	}
	@media (prefers-reduced-motion: no-preference) {
		html {
			scroll-behavior: smooth;
		}
	}
	body {
		font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
		color: var(--paper);
		background: var(--blue);
		line-height: 1.15;
	}
	.wrap {
		max-width: 1440px;
		margin: 0 auto;
		position: relative;
	}

	/* ---------- NAV ---------- */
	nav {
		position: relative;
		z-index: 5;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 34px 56px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 12px;
		font-weight: 700;
		letter-spacing: 0.14em;
		font-size: 15px;
		text-transform: uppercase;
		color: var(--paper);
		text-decoration: none;
	}
	.logo-mark {
		width: 32px;
		height: 32px;
		border-radius: 8px;
		object-fit: contain;
		background: var(--paper);
		padding: 3px;
	}
	.navlinks {
		display: flex;
		gap: 38px;
		font-size: 14px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		font-weight: 500;
	}
	.navlinks a {
		color: var(--paper);
		text-decoration: none;
		opacity: 0.85;
	}
	.navlinks a:hover {
		opacity: 1;
	}
	.nav-toggle {
		display: none;
		width: 32px;
		height: 22px;
		position: relative;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0;
	}
	.nav-toggle span {
		position: absolute;
		left: 0;
		width: 100%;
		height: 2px;
		background: var(--paper);
		transition: transform 0.25s ease, opacity 0.25s ease;
	}
	.nav-toggle span:nth-child(1) {
		top: 0;
	}
	.nav-toggle span:nth-child(2) {
		top: 10px;
	}
	.nav-toggle span:nth-child(3) {
		top: 20px;
	}
	.nav-toggle[aria-expanded='true'] span:nth-child(1) {
		transform: translateY(10px) rotate(45deg);
	}
	.nav-toggle[aria-expanded='true'] span:nth-child(2) {
		opacity: 0;
	}
	.nav-toggle[aria-expanded='true'] span:nth-child(3) {
		transform: translateY(-10px) rotate(-45deg);
	}

	/* ---------- SECTION SHELL (shared across section components) ---------- */
	section.block {
		padding: 96px 56px;
		position: relative;
		z-index: 3;
	}
	.eyebrow {
		font-size: 13px;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		font-weight: 700;
		color: var(--muted);
		margin-bottom: 20px;
	}
	.block h2 {
		font-weight: 700;
		font-size: 84px;
		line-height: 0.9;
		letter-spacing: -0.03em;
		text-transform: capitalize;
		margin-bottom: 34px;
	}
	.see-more {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		margin-top: 44px;
		padding: 15px 30px;
		border: 1.5px solid rgba(255, 255, 255, 0.35);
		border-radius: 40px;
		color: var(--paper);
		text-decoration: none;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}
	.see-more:hover {
		border-color: var(--paper);
	}
	.back-home {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		color: var(--muted);
		text-decoration: none;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		padding: 0 56px;
		margin-top: 8px;
	}
	.back-home:hover {
		color: var(--paper);
	}

	/* ---------- FOOTER ---------- */
	footer {
		padding: 56px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		border-top: 1px solid rgba(255, 255, 255, 0.2);
		position: relative;
		z-index: 3;
		flex-wrap: wrap;
		gap: 16px;
	}
	footer .fbrand {
		font-size: 40px;
		font-weight: 700;
		letter-spacing: -0.03em;
		text-transform: lowercase;
	}
	footer .fnote {
		font-size: 13px;
		letter-spacing: 0.08em;
		color: var(--muted);
		text-transform: uppercase;
		font-weight: 600;
	}

	@media (max-width: 900px) {
		.block h2 {
			font-size: 52px;
		}
		.nav-toggle {
			display: block;
		}
		.navlinks {
			display: none;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			flex-direction: column;
			gap: 0;
			background: var(--blue-deeper);
			padding: 8px 56px 24px;
			border-bottom: 1px solid rgba(255, 255, 255, 0.16);
		}
		.navlinks.open {
			display: flex;
		}
		.navlinks a {
			padding: 14px 0;
			border-bottom: 1px solid rgba(255, 255, 255, 0.12);
		}
		.navlinks a:last-child {
			border-bottom: none;
		}
	}
</style>
