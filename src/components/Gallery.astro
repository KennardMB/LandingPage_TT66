---
import { getCollection } from 'astro:content';

interface Props {
	showSeeMore?: boolean;
}
const { showSeeMore = true } = Astro.props;

const slides = (await getCollection('gallery')).sort((a, b) => a.data.order - b.data.order);
---

<section class="gallery">
	<div class="carousel" data-carousel>
		<div class="carousel-track" data-track>
			{
				slides.map((slide) => (
					<div class="carousel-slide">
						<div class={`slide-image tone-${slide.data.tone}`}>
							<span class="slide-tag">Photo placeholder</span>
						</div>
						<div class="slide-scrim">
							<p class="slide-caption">{slide.data.caption}</p>
						</div>
					</div>
				))
			}
		</div>

		<button class="carousel-arrow prev" data-prev aria-label="Previous slide">‹</button>
		<button class="carousel-arrow next" data-next aria-label="Next slide">›</button>
	</div>

	<div class="carousel-dots" data-dots>
		{slides.map((_, i) => <span class="dot" data-dot={i}></span>)}
	</div>
	{
		showSeeMore && (
			<div class="gallery-see-more">
				<a href="/gallery" class="see-more">
					See more <span aria-hidden="true">→</span>
				</a>
			</div>
		)
	}
</section>

<style>
	.gallery {
		padding: 40px 56px 96px;
		position: relative;
		z-index: 3;
	}
	.carousel {
		position: relative;
		width: 100%;
		aspect-ratio: 2.4 / 1;
		border-radius: 18px;
		overflow: hidden;
	}
	.carousel-track {
		display: flex;
		height: 100%;
		transition: transform 0.5s cubic-bezier(0.65, 0, 0.35, 1);
	}
	.carousel-slide {
		flex: 0 0 100%;
		height: 100%;
		position: relative;
	}
	.slide-image {
		position: absolute;
		inset: 0;
	}
	.slide-image::after {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 30% 24%, rgba(255, 255, 255, 0.16), transparent 55%);
	}
	.tone-a {
		background: linear-gradient(160deg, var(--blue) 0%, var(--blue-deeper) 100%);
	}
	.tone-b {
		background: linear-gradient(200deg, var(--blue-deep) 0%, var(--ink) 100%);
	}
	.tone-c {
		background: linear-gradient(140deg, var(--muted) 0%, var(--blue-deep) 100%);
	}
	.tone-d {
		background: linear-gradient(220deg, var(--blue) 0%, var(--ink) 100%);
	}
	.slide-tag {
		position: absolute;
		top: 20px;
		left: 20px;
		font-size: 11px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--paper);
		background: rgba(0, 0, 0, 0.3);
		padding: 7px 14px;
		border-radius: 20px;
	}
	.slide-scrim {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		padding: 60px 40px 28px;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.25) 55%, transparent 100%);
	}
	.slide-caption {
		max-width: 640px;
		font-size: 19px;
		line-height: 1.4;
		font-weight: 600;
		color: #fff;
	}

	.carousel-arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		width: 44px;
		height: 44px;
		border: none;
		border-radius: 50%;
		background: rgba(0, 0, 0, 0.3);
		color: #fff;
		font-size: 24px;
		line-height: 1;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.carousel-arrow:hover {
		background: rgba(0, 0, 0, 0.5);
	}
	.carousel-arrow.prev {
		left: 20px;
	}
	.carousel-arrow.next {
		right: 20px;
	}

	.carousel-dots {
		display: flex;
		justify-content: center;
		gap: 10px;
		margin-top: 22px;
	}
	.dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.35);
		cursor: pointer;
	}
	.dot.on {
		background: var(--paper);
	}

	@media (max-width: 900px) {
		.carousel {
			aspect-ratio: 3 / 4;
		}
		.carousel-arrow {
			top: 76px;
			transform: none;
			width: 38px;
			height: 38px;
			font-size: 20px;
		}
		.slide-scrim {
			padding: 110px 22px 22px;
			background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.7) 45%, transparent 100%);
		}
		.slide-caption {
			font-size: 15px;
			max-width: 100%;
		}
	}
</style>

<style>
	.gallery-see-more {
		display: flex;
		justify-content: center;
	}
</style>

<script>
	function initCarousel(root: HTMLElement) {
		const track = root.querySelector<HTMLElement>('[data-track]');
		const slides = root.querySelectorAll<HTMLElement>('.carousel-slide');
		const prevBtn = root.querySelector<HTMLElement>('[data-prev]');
		const nextBtn = root.querySelector<HTMLElement>('[data-next]');
		const dotsWrap = root.parentElement?.querySelector<HTMLElement>('[data-dots]');
		const dots = dotsWrap ? Array.from(dotsWrap.querySelectorAll<HTMLElement>('.dot')) : [];
		if (!track || slides.length === 0) return;

		let index = 0;
		let timer: ReturnType<typeof setInterval>;

		function render() {
			track!.style.transform = `translateX(-${index * 100}%)`;
			dots.forEach((dot, i) => dot.classList.toggle('on', i === index));
		}

		function goTo(i: number) {
			index = (i + slides.length) % slides.length;
			render();
		}

		function start() {
			timer = setInterval(() => goTo(index + 1), 5500);
		}
		function stop() {
			clearInterval(timer);
		}

		prevBtn?.addEventListener('click', () => {
			goTo(index - 1);
			stop();
			start();
		});
		nextBtn?.addEventListener('click', () => {
			goTo(index + 1);
			stop();
			start();
		});
		dots.forEach((dot, i) =>
			dot.addEventListener('click', () => {
				goTo(i);
				stop();
				start();
			})
		);
		root.addEventListener('mouseenter', stop);
		root.addEventListener('mouseleave', start);

		render();
		start();
	}

	document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
