---
---

<header class="hero">
	<div class="hero-ghost">66</div>
	<h1>tirta<br />taruna</h1>
	<div class="hero-sub">
		<p>
			Based at Kolam Renang Senayan, GBK Jakarta — we are here to make you
			stronger, and we are here to make you better. Since 1966.
		</p>
		<a href="#contact" class="hero-cta">Join us</a>
	</div>
</header>

<style>
	.hero {
		position: relative;
		z-index: 3;
		padding: 40px 56px 90px;
		min-height: 640px;
	}
	.hero-ghost {
		position: absolute;
		right: 2%;
		top: -4%;
		z-index: -1;
		font-weight: 700;
		font-size: 520px;
		line-height: 0.8;
		color: rgba(255, 255, 255, 0.06);
		letter-spacing: -0.04em;
		user-select: none;
	}
	.hero h1 {
		font-weight: 700;
		font-size: 210px;
		line-height: 0.86;
		letter-spacing: -0.04em;
		text-transform: lowercase;
		color: var(--paper);
	}
	.hero-sub {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 28px;
		margin-top: 38px;
	}
	.hero-sub p {
		max-width: 440px;
		font-size: 22px;
		line-height: 1.4;
		font-weight: 500;
		color: var(--paper);
	}
	.hero-cta {
		display: inline-block;
		background: var(--red);
		color: var(--paper);
		padding: 18px 40px;
		border-radius: 40px;
		font-weight: 700;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-size: 14px;
		text-decoration: none;
		white-space: nowrap;
	}

	@media (max-width: 900px) {
		.hero h1 {
			font-size: 110px;
		}
		.hero-ghost {
			font-size: 220px;
		}
	}
</style>
